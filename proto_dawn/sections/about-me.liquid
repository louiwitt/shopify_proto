<section class="about-me" style="background-color: {{ section.settings.bg_color }}">
  <div class="about-me__inner page-width">

    {%- if section.settings.image != blank -%}
      <div class="about-me__image">
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag: loading: 'lazy', class: 'about-me__img'
        }}
      </div>
    {%- endif -%}

    <div class="about-me__content">
      {%- if section.settings.title != blank -%}
        <h2 class="about-me__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="about-me__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <a href="{{ section.settings.button_url }}" class="button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "t:sections.about-me.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.about-me.settings.bg_color.label",
      "default": "#e7f5f8"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.about-me.settings.image.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.about-me.settings.title.label",
      "default": "t:sections.about-me.settings.title.default"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.about-me.settings.text.label",
      "default": "t:sections.about-me.settings.text.default"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.about-me.settings.button_label.label",
      "default": "t:sections.about-me.settings.button_label.default"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.about-me.settings.button_url.label",
      "default": "t:sections.about-me.settings.button_url.default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.about-me.presets.name"
    }
  ]
}
{% endschema %}